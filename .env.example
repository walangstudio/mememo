# Security settings
MEMEMO_ENABLE_ENCRYPTION=false
MEMEMO_ENCRYPTION_KEY=   # Set for encryption (never commit this!)
MEMEMO_ENABLE_AUDIT_LOG=false
MEMEMO_NETWORK_DETECTION=false  # Enable to detect/block external calls
MEMEMO_SECRETS_DETECTION=true   # Scan for secrets before storing
MEMEMO_AUTO_SANITIZE=false      # Auto-redact secrets (vs reject)

# Storage
MEMEMO_STORAGE_DIR=~/.mememo
# MEMEMO_DATA_DIR is deprecated but still supported for backward compatibility
MEMEMO_MAX_MEMORY_SIZE_MB=10
MEMEMO_MAX_TOTAL_MEMORIES=10000

# Chunking configuration
MEMEMO_CHUNK_MAX_TOKENS=500
MEMEMO_CHUNK_OVERLAP_TOKENS=50

# Search configuration
MEMEMO_SEARCH_TOP_K=5
MEMEMO_SEARCH_MIN_SIMILARITY=0.7

# Vector service (local only)
MEMEMO_VECTOR_SERVICE_URL=http://127.0.0.1:5000
MEMEMO_VECTOR_SERVICE_AUTO_START=true
